# ============================================
# Monitoring — Sentinel (security) + Pulse (observability)
# ============================================
# Both refuse to start in production with default credentials. You have two
# options:
#   (a) Set non-default values for every *_USERNAME / *_PASSWORD / *_SECRET_KEY
#       below, OR
#   (b) Set DEMO_MODE=true (further down) — this is what the public Grit demo
#       does, since the dashboards are intentionally publicly accessible.
# Generate strong secrets with:  openssl rand -hex 32
PULSE_ENABLED=true
PULSE_USERNAME=admin
PULSE_PASSWORD=CHANGE_ME_pulse_strong_password
PULSE_STORAGE=sqlite
PULSE_STORAGE_DSN=/data/pulse.db

SENTINEL_ENABLED=true
SENTINEL_USERNAME=admin
SENTINEL_PASSWORD=CHANGE_ME_sentinel_strong_password
SENTINEL_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
# Comma-separated CIDRs trusted to set X-Forwarded-For. Set to your load
# balancer / reverse-proxy subnet. Leave empty to trust no proxies.
SENTINEL_TRUSTED_PROXIES=

# ============================================
# Demo mode
# ============================================
# When true:
#   - admin@grit.demo / demo123 is auto-seeded on boot
#   - canonical demo cohort (staff, products, motorcycles, loans, sales) is seeded
#   - nightly cron at 03:00 UTC wipes mutable data and reseeds
#   - Resend email sending is disabled (no real emails go out)
#   - Sentinel + Pulse skip their production-credentials gate
# Leave OFF for real production deploys.
DEMO_MODE=false

# DGateway (Desispay) — mobile money collections for loan repayments
DGATEWAY_API_KEY=dgw_live_REPLACE_THIS
DGATEWAY_BASE_URL=
DGATEWAY_DEFAULT_PROVIDER=iotec

# Frontend build-time env vars (MUST match INTERNAL_API_KEY)
VITE_INTERNAL_API_KEY=stk_prod_5ae3bf83dcc7c954415416707ba2d042
VITE_APP_NAME=Grit Motors

# Docker Compose passwords (used by postgres/redis services)
POSTGRES_PASSWORD=dM94KJmfTw8mIAZ43k8aCfRMQjNykkX
REDIS_PASSWORD=BWw8Fsjm4Vike8Qq6eVsuVo0t590Mx
