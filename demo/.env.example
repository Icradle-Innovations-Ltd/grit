# Grit Motors — Environment Variables (demo deployment)

# App
APP_NAME=Grit Motors
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# Demo mode — disables the Resend mailer (so visitors don't trigger
# low-stock / invitation emails) and registers a nightly reset cron
# that wipes mutable data and re-runs the seeder at 00:00 local time.
# Set DEMO_MODE=false (or unset) when scaffolding your own copy.
DEMO_MODE=true

# Database (PostgreSQL — Neon, Supabase, or local)
DATABASE_URL=postgres://user:pass@host:5432/gritdemo?sslmode=require

# JWT
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=720h

# Internal API Key (required on ALL /api/* requests)
INTERNAL_API_KEY=stk_internal_REPLACE_THIS

# Storage — Cloudflare R2
STORAGE_DRIVER=r2
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=REPLACE
R2_SECRET_KEY=REPLACE
R2_BUCKET=gritdemo-images
R2_REGION=auto

# Email (Resend)
RESEND_API_KEY=re_REPLACE_THIS
MAIL_FROM=noreply@gritdemo.app

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# GORM Studio
GORM_STUDIO_ENABLED=true
GORM_STUDIO_USERNAME=admin
GORM_STUDIO_PASSWORD=studio

# Pulse (performance monitoring)
PULSE_ENABLED=false

# Sentinel (security)
SENTINEL_ENABLED=false

# DGateway (Desispay) — mobile money collections for loan repayments
DGATEWAY_API_KEY=
DGATEWAY_BASE_URL=
DGATEWAY_DEFAULT_PROVIDER=iotec

# Frontend env vars
VITE_INTERNAL_API_KEY=stk_internal_REPLACE_THIS
VITE_APP_NAME=Grit Motors
